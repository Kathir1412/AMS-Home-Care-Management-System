## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/ActiveState ActiveGoDB)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
build/
bld/
[Bi]n/
[Oo]bj/
[Log]/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Generated user secrets file
UserSecretsId

# SQL Server files
*.mdf
*.ldf
*.ndf

# Packages
*.nupkg
# NuGet Packages Directory
packages/
# Output folder
publish/

# Local configuration files
appsettings.Development.json
uploads/
