@model AmsHomeCare.Core.Entities.DutyAssignment
@{
    ViewData["Title"] = "Reassign Duty";
}

<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Duties</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit Assignment</li>
            </ol>
        </nav>
        <h2 class="fw-bold text-dark mb-1">Reassign Employee Duty</h2>
        <p class="text-muted">Modify duty constraints or re-schedule timings.</p>
    </div>
</div>

<div class="card card-main" style="max-width: 650px;">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="EmployeeId" class="form-label fw-semibold">Select Care Provider (Employee)</label>
                <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.Employees">
                </select>
                <span asp-validation-for="EmployeeId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PatientId" class="form-label fw-semibold">Select Patient</label>
                <select asp-for="PatientId" class="form-select" asp-items="ViewBag.Patients">
                </select>
                <span asp-validation-for="PatientId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ShiftId" class="form-label fw-semibold">Select Shift Timing</label>
                <select asp-for="ShiftId" class="form-select" asp-items="ViewBag.Shifts">
                </select>
                <span asp-validation-for="ShiftId" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label asp-for="StartDate" class="form-label fw-semibold">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="EndDate" class="form-label fw-semibold">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="SupervisorNotes" class="form-label fw-semibold">Supervisor Instructions / Notes</label>
                <textarea asp-for="SupervisorNotes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="SupervisorNotes" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-floppy-disk me-2"></i> Update Duty
                </button>
                <a asp-action="Index" class="btn btn-light border px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>
