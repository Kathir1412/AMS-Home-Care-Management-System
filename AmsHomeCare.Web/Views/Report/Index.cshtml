@{
    ViewData["Title"] = "Reports Center";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold text-dark mb-1">Reports & Analytics</h2>
        <p class="text-muted">Generate, view, and export operational reports for AMS Home Care.</p>
    </div>
</div>

<div class="row g-4">
    <!-- Card 1: Daily Attendance -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card h-100 card-main">
            <div class="card-body d-flex flex-column text-center p-4">
                <div class="text-primary mb-3">
                    <i class="fa-solid fa-calendar-day fa-3x"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Daily Attendance</h5>
                <p class="text-muted small flex-grow-1">Check logs of check-ins, check-outs, absences and leaves for any specific date.</p>
                <a asp-action="DailyAttendance" class="btn btn-outline-primary w-100 mt-3">Generate Report</a>
            </div>
        </div>
    </div>

    <!-- Card 2: Monthly Summary -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card h-100 card-main">
            <div class="card-body d-flex flex-column text-center p-4">
                <div class="text-success mb-3">
                    <i class="fa-solid fa-calendar-days fa-3x"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Monthly Attendance</h5>
                <p class="text-muted small flex-grow-1">Aggregate attendance logs and overtime hours on a monthly rolling sheet.</p>
                <a asp-action="MonthlyAttendance" class="btn btn-outline-success w-100 mt-3">Generate Report</a>
            </div>
        </div>
    </div>

    <!-- Card 3: Employee Wise -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card h-100 card-main">
            <div class="card-body d-flex flex-column text-center p-4">
                <div class="text-info mb-3">
                    <i class="fa-solid fa-address-book fa-3x"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Employee-Wise Report</h5>
                <p class="text-muted small flex-grow-1">Filter down attendance history, working hours, and leaves for a specific care provider.</p>
                <a asp-action="EmployeeWise" class="btn btn-outline-info w-100 mt-3">Generate Report</a>
            </div>
        </div>
    </div>

    <!-- Card 4: Patient Duties -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card h-100 card-main">
            <div class="card-body d-flex flex-column text-center p-4">
                <div class="text-warning mb-3">
                    <i class="fa-solid fa-briefcase-medical fa-3x"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Patient-Wise Duty</h5>
                <p class="text-muted small flex-grow-1">Analyze shift schedules, caretaker logs, and notes for a specific patient.</p>
                <a asp-action="PatientDuty" class="btn btn-outline-warning w-100 mt-3">Generate Report</a>
            </div>
        </div>
    </div>
</div>
