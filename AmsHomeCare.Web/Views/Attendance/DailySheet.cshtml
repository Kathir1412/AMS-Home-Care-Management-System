@model List<AmsHomeCare.Web.Controllers.AttendanceSheetViewModel>
@using AmsHomeCare.Core.Enums
@{
    ViewData["Title"] = "Mark Daily Attendance";
}

<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Attendance</a></li>
                <li class="breadcrumb-item active" aria-current="page">Daily Sheet</li>
            </ol>
        </nav>
        <h2 class="fw-bold text-dark mb-1">Mark Daily Attendance</h2>
        <p class="text-muted">Perform attendance checks for all active care providers on a selected date.</p>
    </div>
</div>

<div class="card card-main mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end" id="dateForm">
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Attendance Date</label>
                <input type="date" name="date" id="selectedDate" class="form-control" value="@ViewBag.TargetDate" onchange="$('#dateForm').submit();" />
            </div>
            <div class="col-12 col-md-3">
                <span class="text-muted small"><i class="fa-solid fa-circle-info me-1"></i> Date changes reload corresponding sheet.</span>
            </div>
        </form>
    </div>
</div>

<div class="card card-main">
    <div class="card-body">
        <form asp-action="SaveDailySheet" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="date" value="@ViewBag.TargetDate" />

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th>
                            <th>Employee Name</th>
                            <th>Role</th>
                            <th style="width: 20%;">Attendance Status</th>
                            <th>In Time</th>
                            <th>Out Time</th>
                            <th>Overtime (Hrs)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input type="hidden" name="models[@i].EmployeeId" value="@Model[i].EmployeeId" />
                                    <span class="fw-bold">@Model[i].EmployeeCode</span>
                                </td>
                                <td><span class="fw-semibold">@Model[i].EmployeeName</span></td>
                                <td><span class="badge badge-role">@Model[i].Role</span></td>
                                <td>
                                    <select name="models[@i].Status" class="form-select status-select">
                                        @foreach (var val in Enum.GetValues<AttendanceStatus>())
                                        {
                                            if (Model[i].Status == val)
                                            {
                                                <option value="@val" selected="selected">@val</option>
                                            }
                                            else
                                            {
                                                <option value="@val">@val</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input name="models[@i].InTime" type="time" class="form-control time-input" 
                                           value="@Model[i].InTime?.ToString(@"hh\:mm")" />
                                </td>
                                <td>
                                    <input name="models[@i].OutTime" type="time" class="form-control time-input" 
                                           value="@Model[i].OutTime?.ToString(@"hh\:mm")" />
                                </td>
                                <td>
                                    <input name="models[@i].OvertimeHours" type="number" class="form-control" step="0.5" min="0" max="8"
                                           value="@Model[i].OvertimeHours" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-floppy-disk me-2"></i> Save Attendance Sheet
                </button>
                <a asp-action="Index" class="btn btn-light border px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Automatically clear / disable times when marked Absent or On Leave
            $('.status-select').on('change', function () {
                var row = $(this).closest('tr');
                var status = $(this).val();
                if (status === 'Absent' || status === 'Leave') {
                    row.find('.time-input').val('').prop('readonly', true);
                } else {
                    row.find('.time-input').prop('readonly', false);
                }
            });
            $('.status-select').trigger('change');
        });
    </script>
}
