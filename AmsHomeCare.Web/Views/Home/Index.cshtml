@model AmsHomeCare.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold text-dark mb-1">Welcome to AMS Home Care Dashboard</h2>
        <p class="text-muted">Real-time attendance, patient care assignments, and schedules overview.</p>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <!-- Card 1: Total Employees -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stat">
            <div class="card-body d-flex align-items-center justify-content-between p-4">
                <div>
                    <h6 class="text-muted text-uppercase mb-2 fw-semibold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Total Employees</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.TotalEmployees</h3>
                </div>
                <div class="card-stat-icon text-primary">
                    <i class="fa-solid fa-user-nurse"></i>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Card 2: Total Patients -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stat">
            <div class="card-body d-flex align-items-center justify-content-between p-4">
                <div>
                    <h6 class="text-muted text-uppercase mb-2 fw-semibold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Total Patients</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.TotalPatients</h3>
                </div>
                <div class="card-stat-icon text-success">
                    <i class="fa-solid fa-hospital-user"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3: Employees Present Today -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stat">
            <div class="card-body d-flex align-items-center justify-content-between p-4">
                <div>
                    <h6 class="text-muted text-uppercase mb-2 fw-semibold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Present Today</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.PresentToday</h3>
                </div>
                <div class="card-stat-icon text-info">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 4: Employees on Leave -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stat">
            <div class="card-body d-flex align-items-center justify-content-between p-4">
                <div>
                    <h6 class="text-muted text-uppercase mb-2 fw-semibold" style="font-size: 0.8rem; letter-spacing: 0.5px;">On Leave Today</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.OnLeaveToday</h3>
                </div>
                <div class="card-stat-icon text-danger">
                    <i class="fa-solid fa-calendar-minus"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detailed Schedules & Activity -->
<div class="row g-4">
    <!-- Today's Schedule Table -->
    <div class="col-12 col-lg-8">
        <div class="card card-main h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-calendar-day text-primary me-2"></i>Today's Duty Schedule</h5>
                <a asp-controller="Duty" asp-action="Index" class="btn btn-sm btn-primary">View All Assignments</a>
            </div>
            <div class="card-body">
                @if (Model.TodaySchedule != null && Model.TodaySchedule.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Employee</th>
                                    <th>Patient</th>
                                    <th>Shift</th>
                                    <th>Timings</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var assignment in Model.TodaySchedule)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="fw-semibold text-dark">@assignment.Employee?.Name</div>
                                            </div>
                                        </td>
                                        <td>@assignment.Patient?.PatientName</td>
                                        <td>
                                            <span class="badge bg-secondary">@assignment.Shift?.ShiftName</span>
                                        </td>
                                        <td>
                                            @assignment.Shift?.StartTime.ToString(@"hh\:mm") - @assignment.Shift?.EndTime.ToString(@"hh\:mm")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa-solid fa-calendar-xmark fa-3x mb-3 text-secondary"></i>
                        <p class="mb-0">No duties scheduled for today.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Activities Timeline -->
    <div class="col-12 col-lg-4">
        <div class="card card-main h-100">
            <div class="card-header">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>Recent Activities</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    @foreach (var activity in Model.RecentActivities)
                    {
                        <li class="list-group-item px-0 py-3 border-0 border-bottom">
                            <div class="d-flex align-items-start gap-2">
                                <div class="text-primary mt-1">
                                    <i class="fa-solid fa-circle-dot" style="font-size: 0.8rem;"></i>
                                </div>
                                <div>
                                    <p class="mb-0 text-dark small">@activity</p>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
