@model IEnumerable<AmsHomeCare.Core.Entities.Employee>
@{
    ViewData["Title"] = "Employees List";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-dark mb-1">Employee Directory</h2>
            <p class="text-muted">Manage care providers, nurses, caregivers, and staff profiles.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i> Add Employee
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-main">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="employeesTable">
                <thead class="table-light">
                    <tr>
                        <th>Photo</th>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Mobile</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(emp.PhotoPath))
                                {
                                    <img src="@emp.PhotoPath" alt="Photo" class="rounded-circle" style="width: 45px; height: 45px; object-fit: cover;" />
                                }
                                else
                                {
                                    <img src="https://ui-avatars.com/api/?name=@emp.Name&background=e0f2fe&color=0369a1" alt="Avatar" class="rounded-circle" style="width: 45px; height: 45px;" />
                                }
                            </td>
                            <td><span class="fw-bold">@emp.EmployeeCode</span></td>
                            <td>
                                <div class="fw-semibold text-dark">@emp.Name</div>
                                <small class="text-muted">Joined @emp.JoiningDate.ToString("dd-MMM-yyyy")</small>
                            </td>
                            <td>
                                <span class="badge badge-role">@emp.Role</span>
                            </td>
                            <td>@emp.MobileNumber</td>
                            <td>@emp.Email</td>
                            <td>
                                @if (emp.Status == AmsHomeCare.Core.Enums.EmployeeStatus.Active)
                                {
                                    <span class="badge badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-inactive">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="dropdown">
                                    <button class="btn btn-light border btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        Actions
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" asp-action="Details" asp-route-id="@emp.Id">
                                                <i class="fa-solid fa-eye me-2 text-info"></i> View Details
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@emp.Id">
                                                <i class="fa-solid fa-pen-to-square me-2 text-warning"></i> Edit Details
                                            </a>
                                        </li>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="Delete" asp-route-id="@emp.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this employee?');" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="dropdown-item text-danger">
                                                        <i class="fa-solid fa-trash me-2"></i> Delete
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#employeesTable').DataTable({
                responsive: true,
                order: [[1, 'asc']], // Order by Employee Code
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search records..."
                }
            });
        });
    </script>
}
