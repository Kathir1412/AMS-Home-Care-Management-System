@model AmsHomeCare.Core.Entities.Patient
@{
    ViewData["Title"] = "Patient Details";
}

<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Patients</a></li>
                <li class="breadcrumb-item active" aria-current="page">Patient Details</li>
            </ol>
        </nav>
        <h2 class="fw-bold text-dark mb-1">Patient Profile Details</h2>
        <p class="text-muted">Full details of the patient's medical demands and caregiver allocations.</p>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column Summary -->
    <div class="col-12 col-lg-4">
        <div class="card card-main text-center p-4">
            <div class="card-body">
                <div class="mb-3">
                    <span class="rounded-circle shadow d-inline-flex align-items-center justify-content-center bg-light" style="width: 120px; height: 120px; border: 4px solid #f1f5f9;">
                        <i class="fa-solid fa-hospital-user text-success" style="font-size: 3.5rem;"></i>
                    </span>
                </div>
                <h4 class="fw-bold text-dark mb-1">@Model.PatientName</h4>
                <div class="mb-3">
                    <span class="badge bg-secondary px-3 py-2 fw-semibold">@Model.ServiceType</span>
                </div>
                
                <hr class="my-4 text-muted">
                
                <div class="row text-start g-3">
                    <div class="col-6">
                        <small class="text-muted d-block">Patient ID</small>
                        <span class="fw-bold text-dark">#PAT-@Model.Id.ToString("D3")</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Age / Gender</small>
                        <span class="fw-semibold text-dark">@Model.Age Yrs / @Model.Gender</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Care Start</small>
                        <span class="fw-semibold text-dark">@Model.StartDate.ToString("dd-MMM-yyyy")</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Care End</small>
                        <span class="fw-semibold text-dark">@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("dd-MMM-yyyy") : "Ongoing")</span>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="fa-solid fa-pen-to-square me-2"></i> Edit Details
                    </a>
                    <a asp-action="Index" class="btn btn-light border">
                        <i class="fa-solid fa-arrow-left me-2"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column Full Details -->
    <div class="col-12 col-lg-8">
        <div class="card card-main">
            <div class="card-header">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-notes-medical text-primary me-2"></i>Patient Clinical & Assignment Summary</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle" style="font-size: 0.95rem;">
                        <tbody>
                            <tr>
                                <th class="py-3 ps-4" style="width: 30%;">Patient Name</th>
                                <td class="py-3">@Model.PatientName</td>
                            </tr>
                            <tr>
                                <th class="py-3 ps-4">Contact Number</th>
                                <td class="py-3"><a href="tel:@Model.MobileNumber" class="text-decoration-none">@Model.MobileNumber</a></td>
                            </tr>
                            <tr>
                                <th class="py-3 ps-4">Emergency Contact</th>
                                <td class="py-3"><a href="tel:@Model.EmergencyContact" class="text-danger fw-bold text-decoration-none">@Model.EmergencyContact</a></td>
                            </tr>
                            <tr>
                                <th class="py-3 ps-4">Residential Address</th>
                                <td class="py-3">@Model.Address</td>
                            </tr>
                            <tr>
                                <th class="py-3 ps-4">Primary Assigned Caregiver</th>
                                <td class="py-3">
                                    @if (Model.AssignedEmployee != null)
                                    {
                                        <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.AssignedEmployeeId" class="fw-semibold text-primary text-decoration-none">
                                            <i class="fa-solid fa-user-nurse me-1"></i> @Model.AssignedEmployee.Name (@Model.AssignedEmployee.Role)
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No primary caregiver assigned.</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="py-3 ps-4">Medical Condition / Notes</th>
                                <td class="py-3 text-wrap" style="max-width: 400px;">@Model.MedicalCondition</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
