@model IEnumerable<AmsHomeCare.Core.Entities.Patient>
@{
    ViewData["Title"] = "Patients List";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-dark mb-1">Patient Directory</h2>
            <p class="text-muted">Manage patient health profiles and view assigned caregivers.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i> Register Patient
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-main">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="patientsTable">
                <thead class="table-light">
                    <tr>
                        <th>Patient ID</th>
                        <th>Name</th>
                        <th>Age/Gender</th>
                        <th>Service Type</th>
                        <th>Assigned Caregiver</th>
                        <th>Emergency Call</th>
                        <th>Start Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var patient in Model)
                    {
                        <tr>
                            <td><span class="fw-bold text-secondary">#PAT-@patient.Id.ToString("D3")</span></td>
                            <td>
                                <div class="fw-semibold text-dark">@patient.PatientName</div>
                                <small class="text-muted">@patient.MobileNumber</small>
                            </td>
                            <td>@patient.Age Yrs / @patient.Gender</td>
                            <td>
                                <span class="badge bg-secondary">@patient.ServiceType</span>
                            </td>
                            <td>
                                @if (patient.AssignedEmployee != null)
                                {
                                    <div class="d-flex align-items-center">
                                        <i class="fa-solid fa-user-nurse text-primary me-2"></i>
                                        <div class="fw-semibold">@patient.AssignedEmployee.Name</div>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-warning small"><i class="fa-solid fa-triangle-exclamation me-1"></i> Unassigned</span>
                                }
                            </td>
                            <td>
                                <a href="tel:@patient.EmergencyContact" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-phone me-1"></i> Call
                                </a>
                            </td>
                            <td>@patient.StartDate.ToString("dd-MMM-yyyy")</td>
                            <td class="text-end">
                                <div class="dropdown">
                                    <button class="btn btn-light border btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        Actions
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" asp-action="Details" asp-route-id="@patient.Id">
                                                <i class="fa-solid fa-eye me-2 text-info"></i> View Details
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@patient.Id">
                                                <i class="fa-solid fa-pen-to-square me-2 text-warning"></i> Edit Details
                                            </a>
                                        </li>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="Delete" asp-route-id="@patient.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this patient record?');" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="dropdown-item text-danger">
                                                        <i class="fa-solid fa-trash me-2"></i> Delete
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#patientsTable').DataTable({
                responsive: true,
                order: [[0, 'desc']],
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search records..."
                }
            });
        });
    </script>
}
