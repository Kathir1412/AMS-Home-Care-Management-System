@{
    ViewData["Title"] = "Access Denied";
}

<div class="d-flex align-items-center justify-content-center min-vh-100" style="background-color: #f8fafc;">
    <div class="text-center p-5 shadow-sm bg-white rounded-3" style="max-width: 500px;">
        <div class="text-danger mb-4">
            <i class="fa-solid fa-triangle-exclamation fa-4x"></i>
        </div>
        <h1 class="fw-bold text-dark mb-3">Access Denied</h1>
        <p class="text-muted mb-4">You do not have permission to access this resource. Please contact your administrator if you believe this is an error.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2">
            <i class="fa-solid fa-house me-2"></i> Go to Dashboard
        </a>
    </div>
</div>
