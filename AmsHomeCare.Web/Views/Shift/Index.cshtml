@model IEnumerable<AmsHomeCare.Core.Entities.Shift>
@{
    ViewData["Title"] = "Shifts Configuration";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-dark mb-1">Shift Configuration</h2>
            <p class="text-muted">Set up morning, evening, night, or custom duty shifts.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i> Configure Shift
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-main">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Shift Name</th>
                        <th>Start Time</th>
                        <th>End Time</th>
                        <th>Duration</th>
                        <th>Weekly Off Day</th>
                        <th>Type</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var shift in Model)
                    {
                        <tr>
                            <td><span class="fw-bold text-dark">@shift.ShiftName</span></td>
                            <td>@shift.StartTime.ToString(@"hh\:mm")</td>
                            <td>@shift.EndTime.ToString(@"hh\:mm")</td>
                            <td>
                                @{
                                    var duration = shift.EndTime >= shift.StartTime 
                                        ? shift.EndTime - shift.StartTime 
                                        : (TimeSpan.FromHours(24) - shift.StartTime) + shift.EndTime;
                                    @duration.TotalHours.ToString("0.##") <span>Hours</span>
                                }
                            </td>
                            <td>
                                @if (shift.WeeklyOffDay.HasValue)
                                {
                                    <span class="badge bg-light text-dark border"><i class="fa-solid fa-calendar-day me-1"></i> @shift.WeeklyOffDay</span>
                                }
                                else
                                {
                                    <span class="text-muted small">None</span>
                                }
                            </td>
                            <td>
                                @if (shift.IsCustom)
                                {
                                    <span class="badge bg-warning text-dark">Custom</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">Standard</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@shift.Id" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="fa-solid fa-pen-to-square"></i> Edit
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-action="Delete" asp-route-id="@shift.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this shift configuration?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fa-solid fa-trash"></i> Delete
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
